# Modo seguro por defecto. Solo poner true cuando se decida automatizar el guardado real.
ENABLE_FILE_WRITES=false

# Carpeta compartida donde se guardan los .xls por OF (para materiales-ot)
EXPORT_DIRECTORY=\\\\servidor\\ruta\\SUBIDA DE MATERIALES

# Carpeta raíz del archivo anual de pedidos (resumen .xlsx y planteamiento .pdf)
ORDER_ARCHIVE_ROOT=\\\\servidor\\ruta\\Oficina Tecnica

# Puerto del servidor (por defecto 4300)
PORT=4300

# RPSNext: acceso exclusivamente de lectura para catálogos.
DB_SERVER=192.168.0.124
DB_PORT=1433
DB_USER=lectura
DB_PASSWORD=lectura
DB_DATABASE=RPSNext
DB_COMPANY=001
